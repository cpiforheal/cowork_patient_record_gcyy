# Copy this file to .env.local for local-only overrides.
# Mode-specific defaults are kept in .env.development, .env.test, and .env.production.

VITE_GLOB_APP_TITLE=门诊信息管理平台
VITE_PORT=8848
VITE_OPEN=true
VITE_DEVTOOLS=false
VITE_REPORT=false
VITE_CODEINSPECTOR=false

# Optional local API overrides.
VITE_API_URL=/api
VITE_AUTH_API_BASE_URL=/auth
VITE_CLINIC_API_DB_URL=/clinic-api/db
VITE_CLINIC_API_FILES_URL=/clinic-api/files
