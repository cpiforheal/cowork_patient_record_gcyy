# Local runtime config template.
# Copy this file to config/runtime.env and update MYSQL_PASSWORD before starting the backend directly.
SERVER_PORT=8080
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_URL=jdbc:mysql://localhost:3306/hos_refactor?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
CLINIC_ATTACHMENT_DIR=D:\hos_patient_record_runtime\attachments
CLINIC_ATTACHMENT_MAX_SIZE_BYTES=52428800
CLINIC_ATTACHMENT_ALLOWED_MIME_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/bmp,image/gif,application/pdf,text/html
MAX_FILE_SIZE=100MB
MAX_REQUEST_SIZE=100MB
MAX_HTTP_FORM_POST_SIZE=100MB
MAX_SWALLOW_SIZE=100MB

# Optional frontend static directory when the backend serves a packaged Vue build.
CLINIC_FRONTEND_DIR=

# Backup settings. Configure the real backup directory in the admin page after login.
CLINIC_BACKUP_CRON=0 0 2 * * *
CLINIC_BACKUP_ZONE=Asia/Shanghai
CLINIC_BACKUP_MYSQLDUMP_PATH=
CLINIC_MYSQL_DATA_DIR=

# Optional AI settings. Leave keys empty when AI features are not enabled.
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
CLINIC_AI_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
CLINIC_AI_DOUBAO_API_KEY=
CLINIC_AI_DOUBAO_MODEL=doubao-seed-2.0-mini
CLINIC_AI_DOUBAO_TTS_BASE_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional/sse
CLINIC_AI_DOUBAO_TTS_API_KEY=
CLINIC_AI_DOUBAO_TTS_MODEL=seed-tts-2.0-standard
CLINIC_AI_DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
CLINIC_AI_DOUBAO_TTS_VOICE_TYPE=zh_male_tiancaitongsheng_mars_bigtts
CLINIC_AI_DOUBAO_TTS_SPEED_RATIO=1.0
AI_CONFIG_SECRET=
